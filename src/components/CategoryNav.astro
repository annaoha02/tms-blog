---
import { CATEGORIES } from '../consts';

interface Props {
	active?: string;
}

const { active } = Astro.props;
---

<nav class="category-nav">
	<a href="/blog" class={!active ? 'active' : ''}>
		All Posts
	</a>
	{
		CATEGORIES.map((c) => (
			<a href={`/blog/${c.slug}/`} class={active === c.slug ? 'active' : ''}>
				{c.label}
			</a>
		))
	}
</nav>

<style>
	.category-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em 1.2em;
		margin-bottom: 2em;
		padding-bottom: 1em;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.category-nav a {
		color: rgb(var(--gray));
		text-decoration: none;
		font-size: 0.95em;
	}
	.category-nav a.active {
		color: var(--accent);
		font-weight: 700;
	}
	.category-nav a:hover {
		color: var(--accent);
	}
</style>
