---
const today = new Date();
---

<footer>
	<p class="copyright">&copy; {today.getFullYear()} Tokyo Mix Style. All rights reserved.</p>
	<p class="disclosure-note">This site may contain affiliate links.</p>
	<p class="footer-links">
		<a href="/privacy-policy">Privacy Policy</a> · <a href="/contact">Contact</a> ·
		<a href="/affiliate-disclosure">Affiliate Disclosure</a>
	</p>
</footer>
<style>
	footer {
		padding: 3em 1em 6em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
		border-top: 1px solid rgb(var(--gray-light));
	}
	.copyright {
		margin: 0;
		font-size: 0.85em;
	}
	.disclosure-note {
		margin: 0.5em 0 0 0;
		font-size: 0.85em;
		color: rgb(var(--gray));
	}
	.footer-links {
		margin: 0.5em 0 0 0;
		font-size: 0.8em;
		letter-spacing: 0.02em;
	}
	.footer-links a {
		color: rgb(var(--gray));
	}
	.footer-links a:hover {
		color: var(--accent);
	}
</style>
