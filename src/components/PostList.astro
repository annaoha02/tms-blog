---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
	posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

<ul class="post-grid">
	{
		posts.map((post) => (
			<li class="post-card">
				<a href={`/blog/${post.id}/`}>
					<div class="post-card-media">
						{post.data.heroImage && (
							<Image src={post.data.heroImage} alt="" width={480} height={600} />
						)}
					</div>
					<span class="post-card-label">{post.data.category.replace(/-/g, ' ')}</span>
					<h4 class="post-card-title">{post.data.title}</h4>
				</a>
			</li>
		))
	}
</ul>

<style>
	.post-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
		gap: 1.75em 1.5em;
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.post-card a {
		display: block;
		text-decoration: none;
		color: inherit;
	}
	.post-card-media {
		aspect-ratio: 4 / 5;
		overflow: hidden;
		border-radius: 10px;
		margin-bottom: 0.75em;
		background: rgb(var(--gray-light));
	}
	.post-card-media :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 10px;
		margin: 0;
		transition: transform 0.3s ease;
	}
	.post-card a:hover .post-card-media :global(img) {
		transform: scale(1.03);
	}
	.post-card-label {
		display: block;
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 0.3em;
	}
	.post-card-title {
		font-size: 1.05rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		line-height: 1.3;
		margin: 0;
		color: rgb(var(--black));
	}
	@media (max-width: 640px) {
		.post-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 1em 0.75em;
		}
	}
</style>
